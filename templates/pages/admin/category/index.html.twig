{% extends './themes/base_admin.html.twig' %}

{% block title %} Catégories {% endblock %}


    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}


{% block data_tables %}
<link href="https://cdn.datatables.net/v/bs5/dt-2.3.7/datatables.min.css" rel="stylesheet" integrity="sha384-MnxpJFHU9dTMYXshJqBDA0d93sG4KKAFEEzynAaDqcPP7BYh11O5HxbJ6iLDWOXS" crossorigin="anonymous">
 
<script src="https://cdn.datatables.net/v/bs5/dt-2.3.7/datatables.min.js" integrity="sha384-7rAjATpiK3MtvKnoDf5WQz4O8W+3kpl4Jm82apgJgNkeUmZ59yjJT6LqlJpYqhVK" crossorigin="anonymous"></script>

<script>
    $(document).ready( function () {
        $('#table').DataTable({
            language: {
                url:  '//cdn.datatables.net/plug-ins/2.3.7/i18n/fr-FR.json',
            }
        });
    } );
</script>
{% endblock %}

{% block description %} Liste des catégories {% endblock %}

{% block main %} 
<h1 class="text-center my-1 display-5">Catégories</h1>

{% include 'components/_alert.html.twig' %}

<div class="d-flex justify-content-center align-items-center my-5"> 
    <a href="{{path('app_admin_category_create')}}" style="background-color: #a70a08" class="btn text-white"><i class="fa-solid fa-circle-plus"></i> Nouvelle catégorie</a>
</div>

<div class="table-responsive">
    <table id="table" class="table table-striped table-hover table-bordered">
    <thead>

    <tr class="text-white">
    <th>Nom</th>
    <th>Slug</th>
    <th>Créé le</th>
    <th>Modifié le</th>
    <th>Options</th>
    </tr>
    
    </thead>
    <tbody>

    {% for category in categories %}

    <tr class="text-white">
        <td>{{category.name}}</td>
        <td>{{category.slug}}</td>
        <td>{{category.createdAt|format_date}}</td>
        <td>{{category.updatedAt|format_date}}</td>
        <td>
       <a style="background-color: #61d012"  class=" btn text-white" href="{{ path('app_admin_category_edit', {'id': category.id}) }}">Modifier</a>
       <input type="hidden" name="csrf_token" value"{{csrf_token('category-', '~category.id')}}">

       <form action="{{path('app_admin_category_delete', {'id':category.id})}}" method="post">
                                <input type="hidden" name="csrf_token" value="{{csrf_token('delete-category-'~category.id)}}">
                                <input type="submit" class="btn btn-sm btn-danger" value="Supprimer" onclick="return confirm('Confirmer ma suppression de cette catégorie?')">
                            </form>

        </td>
    </tr>
        
    {% endfor %}
    
    </tbody>
    </table>
</div>
 {% endblock %}