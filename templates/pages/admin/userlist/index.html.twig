{% extends './themes/base_admin.html.twig' %}

{% block title %}Utilisateurs{% endblock %}

{% block main %}
<div style="background-color: #811412" class="text-white py-4 text-center">
    <h1 class="display-5" style="font-family: Georgia, serif;">Utilisateurs inscrits</h1>
</div>

<div class="container my-4">
    <table class="table table-striped table-bordered">
        <thead style="background-color: #811412" class="text-white">
            <tr>
                <th>Prénom</th>
                <th>Nom</th>
                <th>Email</th>
                <th>Rôle</th>
                <th>Vérifié</th>
                <th>Inscrit le</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
            <tr>
               
                <td>{{ user.firstName }}</td>
                <td>{{ user.lastName }}</td>
                <td>{{ user.email }}</td>
                <td>
                    {% if 'ROLE_SUPER_ADMIN' in user.roles %}
                        <span class="badge bg-dark">Super Admin</span>
                    {% elseif 'ROLE_ADMIN' in user.roles %}
                        <span class="badge bg-danger">Admin</span>
                    {% else %}
                        <span class="badge bg-secondary">Utilisateur</span>
                    {% endif %}
                </td>
                <td>
                    {% if user.isVerified %}
                        <span class="badge bg-success">Oui</span>
                    {% else %}
                        <span class="badge bg-warning text-dark">Non</span>
                    {% endif %}
                </td>
                <td>{{ user.createdAt ? user.createdAt|date('d/m/Y') : '-' }}</td>
                
            </tr>
            {% else %}
            <tr>
                <td colspan="8" class="text-center">Aucun utilisateur trouvé.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}