{% extends './themes/base_admin.html.twig' %}

{% block title %} Lecture de l'article {{post.id}}: {{post.title}} {% endblock %}

{% block description %} {{post.description}} {% endblock %}

{% block main %} 
<h1 class="text-center my-1"> {{post.title}} </h1>


<div style="background-color: #F5EDE0" class="container">



<div class="d-flex justify-content-center">
   {% if post.image %}
    <img src="{{ vich_uploader_asset(post, 'imageFile') }}" 
         alt="{{ post.title }}" 
         class="img-fluid my-4"
         style="max-width: 300px; height: auto; object-fit: cover;">
{% endif %}
    
</div>
<div>{{post.content|raw}}</div>

</div>
 {% endblock %}