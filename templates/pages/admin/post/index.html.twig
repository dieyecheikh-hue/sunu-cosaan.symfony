{% extends './themes/base_admin.html.twig' %}

{% block title %} Articles {% endblock %}


    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}


{% block data_tables %}
<link href="https://cdn.datatables.net/v/bs5/dt-2.3.7/datatables.min.css" rel="stylesheet" integrity="sha384-MnxpJFHU9dTMYXshJqBDA0d93sG4KKAFEEzynAaDqcPP7BYh11O5HxbJ6iLDWOXS" crossorigin="anonymous">
 
<script src="https://cdn.datatables.net/v/bs5/dt-2.3.7/datatables.min.js" integrity="sha384-7rAjATpiK3MtvKnoDf5WQz4O8W+3kpl4Jm82apgJgNkeUmZ59yjJT6LqlJpYqhVK" crossorigin="anonymous"></script>

<script>
    $(document).ready( function () {
        $('#table').DataTable({
            language: {
                url:  '//cdn.datatables.net/plug-ins/2.3.7/i18n/fr-FR.json',
            }
        });
    } );
</script>
{% endblock %}

{% block description %} Liste des articles {% endblock %}

{% block main %} 
<h1 class="text-center my-1 display-5"> Liste des articles </h1>

{% include 'components/_alert.html.twig' %}

<div class="d-flex justify-content-center align-items-center my-5"> 
    <a href="{{path('app_admin_post_create')}}" style="background-color: #a70a08" class="btn text-white"><i class="fa-solid fa-circle-plus"></i> Nouvel article</a>
</div>


    <div class="table-responsive">
        <table id="table" class="table table-striped table-hover table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Image</th>
                    <th>Titre</th>
                    <th>Catégorie</th>
                    <th>Statut</th>
                    <th>Contenu</th>
                    <th>Créé le</th>
                    <th>Options</th>
                </tr>
            </thead>
            <tbody>

                {% for post in posts %}
                    <tr>
                        <td>

                        {% if post.image %}

                           <img class="d-flex justify-content-center" src="{{ vich_uploader_asset(post, 'imageFile') }}" alt="{{ post.title }}" width="80">
                            {% else %}
                            <p class="text-center">...</p>

                        {% endif %}
                        
                        </td>

                        <td>{{post.title}}</td>

                        <td>{{post.category.name}}</td>
                        
                         <td>
                            {% if post.isPublished %}
                                <p>Publié</p>
                            {% else %}
                                <p>Non publié</p>
                            {% endif %}
                            <form action="{{path("app_admin_post_publish", {'id':post.id})}}" method="post">  
                             <input type="hidden" name="csrf_token" value="{{csrf_token('publish-post-'~post.id)}}">
                            <div class="form-check
                            
                             form-switch">
                                <input 
                                class="form-check-input ms-3" 
                                type="checkbox" 
                                role="switch" 
                                onclick= "return confirm('Confirmer cette action ?')"
                                onchange="this.form.submit();"
                                {{post.isPublished ? 'checked': ''}}
                                >
                            </div>
                              </form>
                            
                         </td>

                        <td>
                            <a class="btn text-white my-4" style="background-color: #1d49b8" href="{{path('app_admin_post_show', {'id': post.id})}}">Lire</a>
                        </td>
                        <td>{{post.createdAt|format_date}}</td>
                        <td>
                        
                          <a style="background-color: #40a708" class="btn text-white" href="{{path('app_admin_post_edit', {'id':post.id})}}">Modifier</a>
                          <form action="{{path('app_admin_post_delete', {'id':post.id})}}" method="post" class="my-3">
                                <input type="hidden" name="csrf_token" value="{{csrf_token('delete-post-'~post.id)}}">
                                <input style="background-color: #a70a08" type="submit" class="btn btn-sm btn-danger" value="Supprimer" onclick="return confirm('Confirmer ma suppression de cette catégorie?')">
                            </form>

                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %} 

