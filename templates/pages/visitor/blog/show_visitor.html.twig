{% extends './themes/base_visitor.html.twig' %}

{% block title %} {{ post.title }} - Sunu Cosaan {% endblock %}

{% block main %}

<div style="background-color: #811412" class="text-white py-4 text-center mb-4">
    <h1 class="display-5" style="font-family: Georgia, serif;">{{ post.title }}</h1>
    <p class="text-white">{{ post.category.name }}</p>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            {% if post.image %}
            <div class="d-flex justify-content-center mb-4">
                <img src="{{ vich_uploader_asset(post, 'imageFile') }}" 
                     alt="{{ post.title }}" 
                     class="img-fluid"
                     style="max-width: 400px; height: auto; object-fit: cover;">
            </div>
            {% endif %}

            <div class="fs-5 mb-4">
                {{ post.content|raw }}
            </div>

            <hr>

            <hr>

<h3 class="mb-4">Commentaires ({{ post.comments|length }})</h3>

{% for comment in post.comments %}
    <div class="card mb-3">
        <div class="card-body">
            <p class="card-text">{{ comment.content }}</p>
            <small class="text-muted">
                {{ comment.user.firstName }} {{ comment.user.lastName }} — 
                {{ comment.createdAt ? comment.createdAt|date('d/m/Y') : '' }}
            </small>
        </div>
    </div>
{% else %}
    <p class="text-muted">Aucun commentaire pour le moment.</p>
{% endfor %}

{% if app.user %}
    <h4 class="mt-4">Laisser un commentaire</h4>
    {{ form_start(commentForm) }}
        {{ form_widget(commentForm.content) }}
        <button type="submit" class="btn text-white mt-2" style="background-color: #811412">
            Envoyer
        </button>
    {{ form_end(commentForm) }}
{% else %}
    <div class="alert text-center mt-4" style="background-color: #d9cab2">
        <p class="mb-1">Vous souhaitez laisser un commentaire ?</p>
        <a href="{{ path('app_register') }}" class="btn text-white mb-3" style="background-color: #811412">S'inscrire</a>
        <a href="{{ path('app_login') }}" style="background-color: #1442e6" class="btn text-white mb-3">Se connecter</a>
    </div>
{% endif %}

<div class="text-center mb-2">
        <a href="{{ path('app_visitor_blog_index') }}" class="btn text-white me-2" style="background-color: #811412" style="background-color: #811412">Retour au blog</a>
</div>

        </div>
    </div>
</div>

{% endblock %}