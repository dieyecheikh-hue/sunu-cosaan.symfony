{% extends './themes/base_visitor.html.twig' %}


{% block title %}Contact | Sunu Cosaan{% endblock %}

{% block main %}
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 shadow p-4">
    
            <div style="background-color: #811412" class="text-white py-4 text-center mb-4">
                <h1 class="display-5" style="font-family: Georgia, serif;">Contactez-nous !</h1>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success text-center">{{ message }}</div>
            {% endfor %}

            {{ form_start(form) }}

                <div class="mb-3">
                    <label>Prénom</label>
                    <div class="text-danger">{{ form_errors(form.firstName) }}</div>
                    {{ form_widget(form.firstName, {'attr': {'class': 'form-control'}}) }}
                </div>

                <div class="mb-3">
                    <label>Nom</label>
                    <div class="text-danger">{{ form_errors(form.lastName) }}</div>
                    {{ form_widget(form.lastName, {'attr': {'class': 'form-control'}}) }}
                </div>

                <div class="mb-3">
                    <label>Email</label>
                    <div class="text-danger">{{ form_errors(form.email) }}</div>
                    {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                </div>


                <div class="mb-3">
                    <label>Message</label>
                    <div class="text-danger">{{ form_errors(form.message) }}</div>
                    {{ form_widget(form.message, {'attr': {'class': 'form-control', 'rows': '5'}}) }}
                </div>

                <button style="background-color: #811412" type="submit" class="btn btn-primary w-100 shadow">Envoyer</button>

            {{ form_end(form) }}

            <p class="text-center mt-3">
                <a href="{{ path('app_visitor_welcome') }}">Retour à l'accueil</a>
            </p>

        </div>
    </div>
</div>
{% endblock %}