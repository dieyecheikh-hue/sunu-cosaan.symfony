<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion | Sunu Cosaan</title>

    <meta name="robots" content="index, follow">
    <meta name="description" content="Connectez-vous pour accéder à votre compte !">
    <meta name="author" content="Cheikh">
    <meta name="publisher" content="Sénégal rekk">
    <meta name="theme-color" content="#e81515da">

    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png">
    <link rel="manifest" href="/images/site.webmanifest">

    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
</head>

<body style="background-color: #F5EDE0">
    {% block body %}
    <div class="d-flex justify-content-center align-items-center vh-100">
        <div class="col-md-6 col-lg-5">

            <h1 class="text-center mb-4">Connectez-vous !</h1>

            {% if error %}
                <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            {% if app.user %}
                <div class="mb-3">
                    Connecté en tant que {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Déconnexion</a>
                </div>
            {% endif %}

            <form method="post">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <div class="mb-3">
                    <label for="inputEmail">Email</label>
                    <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" required autofocus>
                </div>

                <div class="mb-3">
                    <label for="inputPassword">Mot de passe</label>
                    <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" required>
                </div>

                <div class="mb-3">
                  <div class="row">
                      <div class="col-md-6">
                         <label>
                            <input type="checkbox" name="_remember_me">
                            Se souvenir de moi
                         </label>
                      </div>

                      <div class="col-md-6 my-1 text-md-end">
                          <a href="{{path('app_forgot_password_request')}}">Mot de passe oublié ?</a>
                      </div>
                </div>

                <div class="text-center my-1 mb-3">
                    <button class="btn btn-primary w-100 shadow" type="submit">
                        Se connecter
                    </button>
                </div>
            </form>

            <div class="text-center my-3">
            <p>Vous n'avez pas encore de compte ? <a href="{{path('app_register')}}">Inscrivez-vous ici !</a></p>
            </div>

            <div class="text-center my-3">
            <p><a href="{{path('app_visitor_welcome')}}">Retour à l'accueil</a></p>
            </div>

        </div>
    </div>
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</body>
</html>