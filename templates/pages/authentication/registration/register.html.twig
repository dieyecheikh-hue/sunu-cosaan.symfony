<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inscription | Sunu Cosaan, les visages du Sénégal</title>

    <meta name="robots" content="index, follow">
    <meta name="description" content="Inscrivez vous pour ne pas manquer nos prochains articles !">
    <meta name="author" content="Cheikh">
    <meta name="publisher" content="Sénégal rekk">
    <meta name="theme-color" content="#e81515da">

    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png">
    <link rel="manifest" href="/images/site.webmanifest">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer">



    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
</head>

<body style="background-color: #F5EDE0">
<main>
    <div class="d-flex justify-content-center align-items-center vh-100">
        <div class="col-lg-6 py-4">

            <div style="background-color: #811412" class="text-white py-4 text-center mb-4">
               <h1 class="display-5" style="font-family: Georgia, serif;">Inscription</h1>   
           </div>

            {% for flash_error in app.flashes('verify_email_error') %}
                <div class="alert alert-danger text-center" role="alert">{{ flash_error }}</div>
            {% endfor %}

            {{ form_start(registrationForm) }}
            {{ form_errors(registrationForm) }}

            <div class="row mb-3">
                <div class="col-md-6">
                    <label for="registration_form_firstName">Prénom</label>
                    <div class="text-danger">{{ form_errors(registrationForm.firstName) }}</div>
                    {{ form_widget(registrationForm.firstName, {'attr': {'class': 'form-control', 'autofocus': 'autofocus'}}) }}
                </div>
                <div class="col-md-6">
                    <label for="registration_form_lastName">Nom</label>
                    <div class="text-danger">{{ form_errors(registrationForm.lastName) }}</div>
                    {{ form_widget(registrationForm.lastName, {'attr': {'class': 'form-control'}}) }}
                </div>
            </div>

            <div class="mb-3">
                <label for="registration_form_email">Email</label>
                {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div class="mb-3">
                <label for="registration_form_password_first">Mot de passe</label>
                {{ form_widget(registrationForm.password.first, {'attr': {'class': 'form-control', 'placeholder': 'Minimum 12 caractères.'}}) }}
            </div>

            <div class="mb-3">
                <label for="registration_form_password_second">Confirmation du mot de passe</label>
                {{ form_widget(registrationForm.password.second, {'attr': {'class': 'form-control', 'placeholder': 'Minimum 12 caractères.'}}) }}
            </div>
               
            <p class="text-center my-3">
                <a href="{{path('app_forgot_password_request')}}">Mot de passe oublié ?</a>
            </p>
            
            <div>
                <input style="background-color: #811412" type="submit" class="btn btn-primary w-100 shadow my-3" value="S'inscrire">
            </div>

            {{ form_end(registrationForm) }}

            <p class="text-center my-3">
                Déjà un compte ? <a href="{{ path('app_login') }}">Connectez-vous</a>
            </p>
            <p class="text-center my-3">
                <a href="{{ path('app_visitor_welcome') }}">Accueil</a>
            </p>

        </div>
    </div>
</main>

{% block javascripts %}
    {{ encore_entry_script_tags('app') }}
{% endblock %}
</body>
</html>