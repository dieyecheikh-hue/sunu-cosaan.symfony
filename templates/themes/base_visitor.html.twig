<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{% block title %}Sunu Cosaan, les visages du Sénégal{% endblock %}</title>

    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</head>

<body class="mbody">
 
    
    <nav class="navbar navbar-expand-lg bg-success shadow">
        <div class="container-fluid">

            <a class="navbar-brand" href="{{path("app_visitor_welcome")}}">
    <img src="{{ asset('images/logocosaanproto.png') }}" alt="" width="110">
                </a>



            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">

                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="{{path("app_visitor_welcome")}}">Accueil</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="{{path("app_visitor_welcome")}}#about-me">A propos de nous</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="{{path("app_visitor_blog_index")}}#blog">Blog</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="{{path("app_visitor_suggestion_index")}}#suggestion">Vos suggestions</a>
                    </li>

                </ul>

                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">
                        <a class="nav-link" href="#">Se connecter</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">S'inscrire</a>
                    </li>

                </ul>

            </div>
        </div>
    </nav>

    
    <main>
        {% block main %}{% endblock %}
    </main>

    
    <footer class="text-center">
        Sénégal Rekk
    </footer>

</body>
</html>
